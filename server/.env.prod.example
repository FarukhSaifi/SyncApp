# Copy to .env.prod for local production builds — OR run: npm run env:pull (from repo root)
# Same keys as Vercel Production — see docs/VERCEL_ENV.md

NODE_ENV=production
PORT=9000

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/syncapp

JWT_SECRET=your_production_jwt_secret_min_32_chars

ENCRYPTION_KEY=your_production_32_byte_hex_key
ENCRYPTION_IV=your_production_16_byte_hex_iv

CORS_ORIGIN=https://your-frontend.vercel.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI — Google AI Studio only (required for Generate Post / Image / Edit)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_AI_MODEL=gemini-3.5-flash
# Optional image override (Studio native image model)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional GCS cover uploads (not required for AI)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
# GCS_BUCKET_NAME=

# Scheduled publish notifications — see docs/VERCEL_ENV.md (Resend + Namecheap BasicDNS)
# RESEND_API_KEY=re_...
# NOTIFICATION_FROM_EMAIL=SyncApp <noreply@farukh.me>
# NOTIFICATION_CC_EMAIL=farook1x95@gmail.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SITE_URL=https://your-frontend.vercel.app
# CRON_SECRET=your_cron_secret
