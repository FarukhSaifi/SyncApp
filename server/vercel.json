{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**", "node_modules/@vercel/node/**"],
        "maxDuration": 300
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "0 */12 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
