{
  "name": "syncapp-server",
  "version": "2.0.0",
  "description": "Backend API server for SyncApp",
  "main": "dist/src/index.js",
  "scripts": {
    "start": "APP_ENV=prod node dist/src/index.js",
    "dev": "APP_ENV=dev nodemon --watch src --ext ts,js,json --exec 'tsx src/index.ts'",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:setup": "APP_ENV=dev tsx src/database/setup.ts",
    "vercel-build": "echo 'Vercel build complete'"
  },
  "dependencies": {
    "@google-cloud/storage": "7.19.0",
    "@google/genai": "2.6.0",
    "axios": "1.17.0",
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "dayjs": "1.11.20",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.2",
    "multer": "2.1.1",
    "slugify": "1.6.9",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/uuid": "9.0.8",
    "nodemon": "3.1.14",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
