{
  "name": "syncapp-server",
  "version": "1.0.0",
  "description": "Backend API server for SyncApp",
  "main": "dist/src/index.js",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
