# Copy to .env.dev for local development

NODE_ENV=development
PORT=9000

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/syncapp

JWT_SECRET=your_secure_random_string_here_min_32_chars

# Generate: node scripts/generate-keys.js — use the SAME values in dev and prod if you share one MongoDB
ENCRYPTION_KEY=your_64_char_hex_key_here
ENCRYPTION_IV=your_32_char_hex_iv_here

CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# GOOGLE_AI_MODEL=gemini-3.1-flash-lite
