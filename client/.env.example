# Environment Variables for SyncApp Client (Next.js)
# Copy this file to .env and fill in your values.

# ─── Backend API ─────────────────────────────────────────────────────────────
# Development: Next.js proxy forwards /api → http://localhost:9000 automatically
# Production:  Set this to your deployed backend URL
NEXT_PUBLIC_API_BACKEND_URL=http://localhost:9000
# Production example:
# NEXT_PUBLIC_API_BACKEND_URL=https://sync-app-server.vercel.app

# ─── App Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SyncApp
NEXT_PUBLIC_APP_VERSION=2.0.0

# ─── Canonical URL ────────────────────────────────────────────────────────────
# The public-facing base URL of your blog where posts live.
# Used to auto-populate the Canonical URL field in the editor (slug appended).
#   https://yourblog.com/blog  →  canonical = https://yourblog.com/blog/my-post-slug
# If omitted, the post slug is used as the value instead.
NEXT_PUBLIC_CANONICAL_BASE_URL=https://yourblog.com/blog
