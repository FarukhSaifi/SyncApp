# Copy to .env.development (or .env.local) for local development.
# Do NOT run `vercel env pull` into .env.development — it points API calls at production.

NEXT_PUBLIC_API_BACKEND_URL=http://localhost:9000

# Public site URL for metadata / Open Graph (defaults to http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NEXT_PUBLIC_CANONICAL_BASE_URL=https://yourblog.com/blog
