{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.16.1",
    "babel-preset-expo": "~54.0.10",
    "dayjs": "^1.11.21",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.0",
    "expo-dev-client": "~6.0.0",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.0",
    "qs": "^6.15.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/qs": "^6.15.1",
    "@types/react": "~19.1.0",
    "eas-cli": "^20.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.0"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-expo-module-scripts-tsconfig.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "start:go": "expo start --go",
    "android": "bash scripts/with-certs.sh expo run:android",
    "ios": "bash scripts/with-certs.sh expo run:ios",
    "ios:device": "bash scripts/install-ios-device.sh",
    "ios:prebuild": "bash scripts/with-certs.sh expo prebuild --platform ios --clean",
    "ios:release": "IOS_BUILD_CONFIGURATION=Release bash scripts/install-ios-device.sh",
    "pod:install": "bash scripts/with-certs.sh bash -lc 'cd ios && pod install'",
    "prebuild": "bash scripts/with-certs.sh expo prebuild",
    "web": "expo start --web",
    "eas": "eas",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "submit:ios": "eas submit --platform ios --profile production",
    "build:ios:submit": "eas build --platform ios --profile production --auto-submit",
    "setup:ios:production": "bash scripts/eas-setup-production.sh"
  },
  "private": true
}
