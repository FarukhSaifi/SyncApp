# API (required for device builds pointing at your backend)
# Simulator: http://localhost:9000/api
# Physical device: http://<your-mac-lan-ip>:9000/api
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com/api

# Apple — required for device builds and App Store (never commit real .env)
IOS_BUNDLE_IDENTIFIER=com.yourcompany.syncapp
APPLE_TEAM_ID=XXXXXXXXXX

# Android (optional — defaults to IOS_BUNDLE_IDENTIFIER)
# ANDROID_PACKAGE=com.yourcompany.syncapp

# Physical device install (optional — auto-detects first USB iPhone)
# EXPO_IOS_DEVICE=

# iOS native build (default: latest — see config/iosDefaults.js)
IOS_DEPLOYMENT_TARGET=26.0
IOS_BUILD_NUMBER=1
# IOS_SUPPORTS_TABLET=true
# IOS_BUILD_CONFIGURATION=Release
# IOS_REGEN=1

# EAS — set EXPO_PUBLIC_API_BASE_URL + IOS_BUNDLE_IDENTIFIER as EAS secrets for production
# Optional override — default is in config/app.js (run `npm run eas:init` from repo root)
# EAS_PROJECT_ID=fc6f629e-e523-46cd-8c38-90f3b1736067

# App Store submit (optional — copy eas.submit.example.json → eas.submit.json, gitignored)
# APPLE_ID=you@example.com
# ASC_APP_ID=0000000000
